# ============================================================================
# Mnemos — .gitignore
# ============================================================================
# Repo is at the project root; this applies to the whole tree.

# ---- Local environment files ------------------------------------------------
# The end-user .env file may contain real secrets (PG password, session key).
.env
.env.*
!.env.example

# ---- Production compose bind mounts ----------------------------------------
# These directories back the named volumes in the production compose file.
# They are intentionally committed-ignored so user data never gets into git.
/vector-db/
/mnemos/backend/
/mnemos/frontend/

# ---- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/

# ---- Virtualenvs ------------------------------------------------------------
venv/
.venv/
env/
ENV/

# ---- Editor / OS noise ------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
