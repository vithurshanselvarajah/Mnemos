#!/usr/bin/env bash
# Mnemos DEV build / cleanup helper.
#
# This script is for people working on the Mnemos source. It builds the
# images from the local source tree (using docker-compose.dev.yml) and
# provides the usual dev workflow commands.
#
# Normal end-users should NOT use this script — they should use the
# production docker-compose.yml directly, which pulls prebuilt images
# from GitHub Container Registry:
#
#   docker compose pull
#   docker compose up -d
#
# Usage:
#   bin/mnemos build [compose-args...]   # build images (default: docker compose -f docker-compose.dev.yml build)
#   bin/mnemos up    [compose-args...]   # build + start the stack
#   bin/mnemos down                       # stop the stack (keeps images + volumes)
#   bin/mnemos delete images [-y]         # remove the Mnemos docker images
#   bin/mnemos delete data   [-y]         # remove the Mnemos docker volumes (data, crops, pgvector)
#   bin/mnemos delete all    [-y]         # images + data + stopped containers
#   bin/mnemos status                     # show running containers + volume sizes
#   bin/mnemos logs [service]             # tail logs for a service (or all)
#
# The script never touches anything outside the `mnemos*` namespace, so it
# is safe to run on a host that hosts other projects.
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

PROJECT_PREFIX="mnemos"
# This script is for DEV work. It always uses the dev compose file which
# builds images from the local source tree, never the production compose
# file (which pulls prebuilt images from GHCR).
COMPOSE=(docker compose -f docker-compose.dev.yml)

say()  { printf '\033[1;34m[mnemos]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[mnemos]\033[0m %s\n' "$*" >&2; }
err()  { printf '\033[1;31m[mnemos]\033[0m %s\n' "$*" >&2; }
die()  { err "$*"; exit 1; }

require_docker() {
    if ! command -v docker >/dev/null 2>&1; then
        die "docker is not installed or not on PATH"
    fi
    if ! docker info >/dev/null 2>&1; then
        die "docker daemon is not reachable (try: sudo systemctl start docker, or add yourself to the 'docker' group)"
    fi
}

confirm() {
    if [[ "${YES:-0}" == "1" ]]; then return 0; fi
    local prompt="$1"
    if [[ ! -t 0 ]]; then
        die "Refusing to run destructive command without -y in non-interactive mode"
    fi
    read -r -p "$prompt [y/N] " ans
    [[ "$ans" =~ ^[Yy]$ ]]
}

list_mnemos_images() {
    # The dev images built by `docker compose -f docker-compose.dev.yml` get
    # the compose project name prepended to their tag, e.g. "mnemosv2-mnemos-backend".
    # Production images live under "ghcr.io/vithurshanselvarajah/mnemos-*" and
    # are intentionally NOT managed by this script.
    docker images --format '{{.Repository}}:{{.Tag}} {{.ID}}' \
        | awk -v pfx="${PROJECT_PREFIX}v2-" '
            $1 ~ ("^" pfx) { print $2 }
        ' \
        | sort -u
}

list_mnemos_volumes() {
    docker volume ls --format '{{.Name}}' \
        | awk -v pfx="$PROJECT_PREFIX" '$0 ~ pfx { print }' \
        | sort -u
}

list_mnemos_containers() {
    docker ps -a --filter "name=$PROJECT_PREFIX" --format '{{.ID}} {{.Names}}' || true
}

image_count()  { list_mnemos_images  | grep -c . || true; }
volume_count() { list_mnemos_volumes | grep -c . || true; }
container_count() { list_mnemos_containers | grep -c . || true; }

cmd_build() {
    require_docker
    say "Building images (no cache)…"
    "${COMPOSE[@]}" build "$@"
}

cmd_up() {
    require_docker
    say "Building + starting stack…"
    "${COMPOSE[@]}" up -d --build "$@"
    cmd_status
}

cmd_down() {
    require_docker
    say "Stopping stack (keeping images + volumes)…"
    "${COMPOSE[@]}" down
}

cmd_version() {
    read_version() {
        local f="$1"
        if [[ -f "$f" ]]; then
            sed -n 's/^__version__[[:space:]]*=[[:space:]]*["'"'"']\([^"'"'"']*\)["'"'"'].*/\1/p' "$f" | head -n1
        else
            echo "(missing)"
        fi
    }
    say "Versions embedded in the source:"
    printf '  %-12s %s\n' "backend:"   "$(read_version "$ROOT_DIR/mnemos-backend/app/_version.py")"
    printf '  %-12s %s\n' "frontend:"  "$(read_version "$ROOT_DIR/mnemos-frontend/app/_version.py")"
    printf '\nEdit the value of __version__ in the *_version.py file to bump.\n'
}

cmd_status() {
    require_docker
    say "Containers:"
    if [[ "$(container_count)" -gt 0 ]]; then
        docker ps -a --filter "name=$PROJECT_PREFIX" --format '  {{.Names}}\t{{.Status}}\t{{.Ports}}'
    else
        echo "  (none)"
    fi
    say "Volumes:"
    if [[ "$(volume_count)" -gt 0 ]]; then
        docker volume ls --filter "name=$PROJECT_PREFIX" --format '  {{.Name}}\t{{.Driver}}'
    else
        echo "  (none)"
    fi
    say "Images:"
    if [[ "$(image_count)" -gt 0 ]]; then
        docker images --format '  {{.Repository}}:{{.Tag}}\t{{.Size}}' \
            | awk -v pfx="$PROJECT_PREFIX" '$1 ~ pfx || $1 ~ ("/" pfx) { print }'
    else
        echo "  (none)"
    fi
}

cmd_logs() {
    require_docker
    "${COMPOSE[@]}" logs -f "$@"
}


delete_images() {
    require_docker
    local n; n=$(image_count)
    if [[ "$n" -eq 0 ]]; then
        say "No Mnemos images to remove."
        return 0
    fi
    say "The following $n Mnemos image(s) will be removed:"
    list_mnemos_images | sed 's/^/  /'
    confirm "Proceed?" || { say "Aborted."; return 0; }
    "${COMPOSE[@]}" down --remove-orphans >/dev/null 2>&1 || true
    list_mnemos_images | xargs -r docker rmi -f
    say "Removed $n image(s)."
}

delete_data() {
    require_docker
    local n; n=$(volume_count)
    if [[ "$n" -eq 0 ]]; then
        say "No Mnemos volumes to remove."
        return 0
    fi
    say "The following $n Mnemos volume(s) (and ALL of their data) will be removed:"
    list_mnemos_volumes | sed 's/^/  /'
    warn "This will permanently delete the SQLite DBs, crop JPEGs, and pgvector data."
    confirm "Proceed?" || { say "Aborted."; return 0; }
    "${COMPOSE[@]}" down --volumes --remove-orphans >/dev/null 2>&1 || true
    list_mnemos_volumes | xargs -r docker volume rm
    say "Removed $n volume(s)."
}

delete_all() {
    require_docker
    say "Stopping containers, removing images, removing volumes…"
    "${COMPOSE[@]}" down --volumes --remove-orphans --rmi all >/dev/null 2>&1 || true
    local imgs vols
    imgs=$(list_mnemos_images)
    vols=$(list_mnemos_volumes)
    if [[ -n "$imgs" ]]; then echo "$imgs" | xargs -r docker rmi -f; fi
    if [[ -n "$vols" ]]; then echo "$vols" | xargs -r docker volume rm; fi
    say "Mnemos is fully removed from this host."
}

cmd_delete() {
    local target="${1:-}"; shift || true
    case "$target" in
        images) delete_images "$@";;
        data)   delete_data "$@";;
        all)    delete_all "$@";;
        -h|--help|help|"")
            cat <<EOF
Usage: bin/mnemos delete <images|data|all> [-y]

  images  Remove the docker images built for this project (no data loss).
  data    Remove the docker volumes (backend.db, frontend.db, crops, pgvector data).
  all     Remove images + data + any stopped containers.

  -y      Skip the confirmation prompt (use carefully).
EOF
            ;;
        *) die "Unknown delete target: $target (use: images | data | all)";;
    esac
}


main() {
    if [[ $# -lt 1 ]]; then
        cat <<EOF
Mnemos DEV management script.

This script builds the images from source and runs the dev stack. End-users
should use the production docker-compose.yml instead:
  docker compose pull
  docker compose up -d

Usage:
  bin/mnemos build                 Build the docker images from source.
  bin/mnemos up                    Build + start the dev stack (detached).
  bin/mnemos down                  Stop the dev stack.
  bin/mnemos status                Show containers, volumes, images.
  bin/mnemos logs [service]        Tail logs.
  bin/mnemos version               Print the embedded backend/frontend versions.
  bin/mnemos delete <images|data|all> [-y]
                                   Remove images / volumes / everything.
EOF
        exit 0
    fi
    local args=()
    for a in "$@"; do
        case "$a" in
            -y|--yes) YES=1;;
            *) args+=("$a");;
        esac
    done
    set -- "${args[@]}"

    local cmd="$1"; shift
    case "$cmd" in
        build)   cmd_build "$@";;
        up)      cmd_up "$@";;
        down)    cmd_down "$@";;
        status)  cmd_status;;
        logs)    cmd_logs "$@";;
        delete)  cmd_delete "$@";;
        version) cmd_version;;
        -h|--help|help) main;;
        *) die "Unknown command: $cmd (try: build | up | down | status | logs | delete | version)";;
    esac
}

main "$@"
