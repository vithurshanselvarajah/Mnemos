meta {
  name: "List API keys"
  type: "http"
  seq: 1
}

get {
  url: {{baseUrl}}/api/v1/keys
  body: none
  auth: none
}

docs {
  List all API keys (including revoked ones), newest first. Only the
  `key_prefix` and metadata are shown — the raw key is only returned once at
  creation.

  - **Permission:** Full-Admin.
}

settings {
  encodeUrl: true
}
